{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "console": "internalConsole",
            "program": "godot",
            "logging": {
                "moduleLoad": false
            },
            "cwd": "${workspaceFolder}",
            "enableStepFiltering": false
        },
        {
            "name": "Debug Scene",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "console": "internalConsole",
            "program": "godot",
            "logging": {
                "moduleLoad": false
            },
            "args": [
                "${fileDirname}/${fileBasenameNoExtension}.tscn"
            ],
            "cwd": "${workspaceFolder}",
            "enableStepFiltering": false
        },
        {
            "name": "Attach",
            "type": "coreclr",
            "request": "attach",
            "enableStepFiltering": false
        }
    ]
}